{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "moduleResolution": "node",
    "baseUrl": "."
  },
  "include": [
    "core/**/*",
    "api/**/*",
    "pages/**/*",
    "components/**/*",
    "flows/**/*",
    "utils/**/*",
    "testdata/**/*",
    "tests/**/*",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist", "reports"]
}
